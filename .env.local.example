# Copy to .env.local (gitignored) for local development.

# Fine-grained GitHub PAT, read-only "Contents" access scoped to the
# mllws/mllws-blog repo only. Used by scripts/fetch-blog-content.js to
# pull blog posts at build/dev time. Leave unset to develop without
# blog content (the blog will just render empty).
BLOG_CONTENT_TOKEN=

# Feature flags (see flags.js). Connect an Edge Config store to this
# project in the Vercel dashboard (Storage > Edge Config) and Vercel will
# fill this in automatically for Production/Preview/Development. Leave
# unset locally to develop with all flags at their defaultValue.
EDGE_CONFIG=

# Used to sign Flags Explorer overrides (Vercel Toolbar) and to authorize
# the app/.well-known/vercel/flags discovery endpoint. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# Use a different value per environment.
FLAGS_SECRET=
